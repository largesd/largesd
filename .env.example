# Blind Debate Adjudicator - environment defaults

# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------
# Use a strong random value outside local development.
SECRET_KEY=dev-secret-key-change-in-production

# Runtime environment (`development`, `staging`, `production`).
ENV=development

# JWT lifetime (hours).
JWT_EXPIRATION_HOURS=24

# Leave enabled in deployed environments; default broad limits only apply to
# mutating `/api/` requests, not page navigation or read-only GETs.
# ENABLE_RATE_LIMITER=true

# SQLite database path.
DEBATE_DB_PATH=data/debate_system.db

# -----------------------------------------------------------------------------
# Model + scoring configuration
# -----------------------------------------------------------------------------
# Options: mock, openai, openrouter, openrouter-multi
LLM_PROVIDER=mock

# Number of judges used in scoring replicates.
NUM_JUDGES=5

# Fact-check mode: OFFLINE or ONLINE_ALLOWLIST
FACT_CHECK_MODE=OFFLINE

# OpenRouter (required when LLM_PROVIDER is openrouter or openrouter-multi)
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# OPENROUTER_TIMEOUT_SECONDS=60
# ALLOW_MOCK_FALLBACK=false

# Optional site info for OpenRouter rankings
# SITE_URL=https://your-site.com
# SITE_NAME=Debate System

# OpenAI (required when LLM_PROVIDER is openai)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Admin API access policy
# -----------------------------------------------------------------------------
# open: anyone can access admin APIs (local-only use)
# authenticated: only logged-in users with is_admin=True can access admin APIs
# restricted: only users with is_admin=True OR those listed in ADMIN_USER_EMAILS/ADMIN_USER_IDS
ADMIN_ACCESS_MODE=authenticated

# Comma-separated allow lists used only when ADMIN_ACCESS_MODE=restricted
# ADMIN_USER_EMAILS=admin@example.com,ops@example.com
# ADMIN_USER_IDS=user_abc123,user_def456

# ---------------------------------------------------------------------------
# Email ingestion (IMAP) — required for email_processor.py
# ---------------------------------------------------------------------------
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=debate-inbox@gmail.com
IMAP_PASSWORD=your-app-password
IMAP_FOLDER=INBOX
IMAP_USE_SSL=true

# ---------------------------------------------------------------------------
# Email acknowledgments (SMTP) — optional but recommended
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=debate-inbox@gmail.com
SMTP_PASSWORD=your-app-password

# ---------------------------------------------------------------------------
# GitHub publishing — required for github_publisher.py
# ---------------------------------------------------------------------------
GITHUB_REPO=owner/repo
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_BRANCH=main
GITHUB_RESULTS_PATH=data/consolidated_results.json
GITHUB_AUTHOR_NAME=Blind Debate Adjudicator
GITHUB_AUTHOR_EMAIL=bot@debate.local

# ---------------------------------------------------------------------------
# Email processor behavior
# ---------------------------------------------------------------------------
PROCESSOR_DEST_EMAIL=debate-inbox@gmail.com
SENDER_WHITELIST=
MARK_PROCESSED=true
POLL_INTERVAL=60
