# Blind Debate Adjudicator - Environment Configuration

# ============================================
# LLM Provider Configuration
# ============================================

# Options: mock, openai, openrouter, openrouter-multi
# - mock: Uses deterministic mock responses (default, no API key needed)
# - openai: Uses OpenAI API (requires OPENAI_API_KEY)
# - openrouter: Uses OpenRouter with single model
# - openrouter-multi: Uses multiple different models for judge diversity
LLM_PROVIDER=mock

# Number of judges for multi-judge evaluation (MSD §10)
# Each judge = 1 LLM call, so costs scale linearly
NUM_JUDGES=5

# ============================================
# OpenRouter Configuration
# ============================================

# Get your API key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxx

# Optional: Your site info (helps with OpenRouter rankings)
# SITE_URL=https://your-site.com
# SITE_NAME=My Debate System

# ============================================
# OpenAI Configuration (if using openai provider)
# ============================================

# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# ============================================
# Fact Checking Configuration
# ============================================

# Options: OFFLINE, ONLINE_ALLOWLIST
# - OFFLINE: Returns p=0.5 for all facts (default)
# - ONLINE_ALLOWLIST: Uses fact checking skill (requires setup)
FACT_CHECK_MODE=OFFLINE

# ============================================
# Authentication Configuration
# ============================================

# JWT Secret Key - CHANGE THIS IN PRODUCTION!
# Generate a secure key with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-secret-key-change-this-in-production

# Token expiration in hours
JWT_ACCESS_TOKEN_EXPIRES=24

# ============================================
# Example Configurations
# ============================================

# --- Development (Free) ---
# LLM_PROVIDER=mock
# NUM_JUDGES=3

# --- Production with OpenRouter (Single Model) ---
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx
# NUM_JUDGES=5

# --- Production with OpenRouter (Multi-Model Judges) ---
# LLM_PROVIDER=openrouter-multi
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxx
# NUM_JUDGES=5
# This uses different models for each judge (Claude, GPT, Gemini, etc.)
